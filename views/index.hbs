{{!< layout}}

<!-- 英雄区域 -->
<section class="hero">
    <div class="hero-container">
        <div class="hero-content">
            <div class="hero-text">
                <div class="hero-badge">5月29日 AI头条</div>
                <h1 class="hero-title">正式开源！DeepSeek-R1-0528震撼发布，性能直逼OpenAI o3，免费API已上线</h1>
                <button class="hero-btn">查看头条</button>
            </div>
            <div class="hero-image">
                <img src="https://ext.same-assets.com/155488376/4141911314.jpeg" alt="DeepSeek" class="hero-img">
            </div>
        </div>
    </div>
</section>

<!-- 新鲜AI资讯 -->
<section class="news-section">
    <div class="section-container">
        <div class="section-header">
            <h2 class="section-title">新鲜AI资讯</h2>
            <p class="section-subtitle">实时更新AI行业的最新资讯</p>
            <div class="section-tabs">
                <span class="tab active">最新</span>
                <span class="tab">视频</span>
                <span class="tab">热门</span>
            </div>
        </div>

        <div class="news-grid">
            {{#each newsItems}}
            <article class="news-item">
                <div class="news-meta">
                    <time class="news-date">{{date}}</time>
                </div>
                <h3 class="news-title">{{title}}</h3>
            </article>
            {{/each}}
        </div>
    </div>
</section>

<!-- 热门AI榜单 -->
<section class="ranking-section">
    <div class="section-container">
        <div class="section-header">
            <h2 class="section-title">热门AI榜单</h2>
            <div class="ranking-tabs">
                <div class="ranking-tab active">
                    <span class="tab-icon">🔥</span>
                    <span class="tab-text">最新收录推荐</span>
                    <small class="tab-desc">全面展示优质AI产品推荐</small>
                </div>
                <div class="ranking-tab">
                    <span class="tab-icon">📈</span>
                    <span class="tab-text">周流量暴涨升级</span>
                    <small class="tab-desc">周流量暴涨的AI产品排行</small>
                </div>
                <div class="ranking-tab">
                    <span class="tab-icon">📊</span>
                    <span class="tab-text">月流量暴涨升级</span>
                    <small class="tab-desc">月流量暴涨AI产品排行</small>
                </div>
            </div>
        </div>

        <div class="tools-grid">
            {{#each hotTools}}
            <div class="tool-card">
                <div class="tool-rank">{{add @index 1}}</div>
                <div class="tool-icon">
                    <img src="{{icon}}" alt="{{name}}" class="tool-icon-img">
                </div>
                <div class="tool-info">
                    <h4 class="tool-name">{{name}}</h4>
                    <p class="tool-desc">{{description}}</p>
                </div>
                <div class="tool-stats">
                    <div class="tool-visitors">{{visitors}}</div>
                    <div class="tool-change positive">{{change}}</div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>

<!-- AI分类榜 -->
<section class="categories-section">
    <div class="section-container">
        <div class="section-header">
            <h2 class="section-title">热门AI分类榜</h2>
            <p class="section-subtitle">展现各个AI类头技术产品专属的流量变化</p>
        </div>

        <div class="categories-nav">
            {{#each categories}}
            <div class="category-tab {{#if @first}}active{{/if}}">
                <span class="category-icon">{{icon}}</span>
                <span class="category-name">{{name}}</span>
            </div>
            {{/each}}
        </div>

        <div class="category-header">
            <h3>中文 TOP ：</h3>
        </div>

        <div class="category-tools-grid">
            <div class="category-tool featured">
                <div class="tool-content">
                    <div class="tool-label github">视频生成</div>
                    <h4>SkyReels-V2</h4>
                    <p>全球首个无需时长限制的视频生成AI系统，开启移动原创视频时代</p>
                    <div class="tool-metrics">
                        <span class="metric">👥 82.9M</span>
                        <span class="metric negative">❤️ -25.45 %</span>
                    </div>
                </div>
            </div>

            <div class="category-tool">
                <div class="tool-content">
                    <div class="tool-label research">研究工具</div>
                    <h4>arxiv_summarizer</h4>
                    <p>自动化按收论文 arXiv 论文的文文检索Python工具</p>
                    <div class="tool-metrics">
                        <span class="metric">👥 82.9M</span>
                        <span class="metric negative">❤️ -25.45 %</span>
                    </div>
                </div>
            </div>

            <div class="category-tool">
                <div class="tool-content">
                    <div class="tool-label automation">自动化</div>
                    <h4>Magentic-UI</h4>
                    <p>一个人性化的迹代界面系统，自动化网站开发</p>
                    <div class="tool-metrics">
                        <span class="metric">👥 82.9M</span>
                        <span class="metric negative">❤️ -25.45 %</span>
                    </div>
                </div>
            </div>

            <div class="category-tool">
                <div class="tool-content">
                    <div class="tool-label ai">微软高频</div>
                    <h4>DeepSeek</h4>
                    <p>与DeepSeek AI跨文</p>
                    <div class="tool-metrics">
                        <span class="metric">👥 78.1M</span>
                        <span class="metric negative">❤️ -16.67 %</span>
                    </div>
                </div>
            </div>

            <!-- 第二行 -->
            <div class="category-tool">
                <div class="tool-content">
                    <h4>Do Browser</h4>
                    <p>一站式轻量纷化在命名操作的浏览器扩展</p>
                    <div class="tool-metrics">
                        <span class="metric">👥 31.6M</span>
                        <span class="metric negative">❤️ -28.55 %</span>
                    </div>
                </div>
            </div>

            <div class="category-tool">
                <div class="tool-content">
                    <h4>Photo Stock Assistant</h4>
                    <p>简化Adobe Stock上照片上传洞察的Chrome插件</p>
                    <div class="tool-metrics">
                        <span class="metric">👥 31.6M</span>
                        <span class="metric negative">❤️ -28.55 %</span>
                    </div>
                </div>
            </div>

            <div class="category-tool">
                <div class="tool-content">
                    <h4>New Tab Widgets</h4>
                    <p>在谷歌浏览器中址大开屏，增栏Hue灯光，天气，控股...</p>
                    <div class="tool-metrics">
                        <span class="metric">👥 31.6M</span>
                        <span class="metric negative">❤️ -28.55 %</span>
                    </div>
                </div>
            </div>

            <div class="category-tool">
                <div class="tool-content">
                    <h4>Supercut - Screen...</h4>
                    <p>快感分享屏幕和规模宽含，创建专业界域、适用于内部朋友减负</p>
                    <div class="tool-metrics">
                        <span class="metric">👥 31.6M</span>
                        <span class="metric negative">❤️ -28.55 %</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- AI开源项目 -->
<section class="projects-section">
    <div class="section-container">
        <div class="section-header">
            <h2 class="section-title">热门AI开源项目</h2>
            <p class="section-subtitle">为你提供最全面的AI开源项目库</p>
        </div>

        <div class="projects-categories">
            <div class="project-category">
                <h3>热门AI开源项目</h3>
                <p>3179 repositories</p>
                <div class="project-list">
                    <div class="project-item">
                        <span class="project-rank">1</span>
                        <span class="project-name">M MLLMCelltype</span>
                        <span class="project-stars">▲ 68</span>
                    </div>
                    <div class="project-item">
                        <span class="project-rank">2</span>
                        <span class="project-name">M Mcp Containers</span>
                        <span class="project-stars">▲ 50</span>
                    </div>
                </div>
            </div>

            <div class="project-category">
                <h3>TTS</h3>
                <p>13 repositories</p>
                <div class="project-list">
                    <div class="project-item">
                        <span class="project-rank">1</span>
                        <span class="project-name">B Bert VITS2 MNN</span>
                        <span class="project-stars">▲ 15</span>
                    </div>
                    <div class="project-item">
                        <span class="project-rank">2</span>
                        <span class="project-name">A Anyrobo</span>
                        <span class="project-stars">▲ 2</span>
                    </div>
                </div>
            </div>

            <div class="project-category">
                <h3>Deepseek</h3>
                <p>32 repositories</p>
                <div class="project-list">
                    <div class="project-item">
                        <span class="project-rank">1</span>
                        <span class="project-name">E EShopLite</span>
                        <span class="project-stars">▲ 5</span>
                    </div>
                    <div class="project-item">
                        <span class="project-rank">2</span>
                        <span class="project-name">S Secai</span>
                        <span class="project-stars">▲ 5</span>
                    </div>
                </div>
            </div>

            <div class="project-category">
                <h3>STT</h3>
                <p>5 repositories</p>
                <div class="project-list">
                    <div class="project-item">
                        <span class="project-rank">1</span>
                        <span class="project-name">D Dria Livekit Agent Deep R</span>
                        <span class="project-stars">▲ 1</span>
                    </div>
                    <div class="project-item">
                        <span class="project-rank">2</span>
                        <span class="project-name">G GenAI Hub Space</span>
                        <span class="project-stars">▲ 0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 最新实现指南 -->
<section class="guides-section">
    <div class="section-container">
        <div class="section-header">
            <h2 class="section-title">最新实现指南</h2>
            <p class="section-subtitle">获取最新AI循环次数或实操案例</p>
        </div>

        <div class="guides-grid">
            {{#each featured}}
            <div class="guide-card">
                <div class="guide-image">
                    <img src="{{image}}" alt="{{title}}" class="guide-img">
                </div>
                <div class="guide-content">
                    <h4 class="guide-title">{{title}}</h4>
                    <div class="guide-stats">
                        <span class="guide-views">閲读量: {{views}}</span>
                        <span class="guide-category">{{category}}</span>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>

{{!< layout}}

<!-- 页面头部 -->
<section class="page-header">
    <div class="section-container">
        <h1 class="page-title">AI资讯</h1>
        <p class="page-subtitle">实时更新AI行业的最新资讯</p>

        <div class="news-filters">
            <div class="filter-tabs">
                <span class="filter-tab active">全部</span>
                <span class="filter-tab">AI头条</span>
                <span class="filter-tab">产品发布</span>
                <span class="filter-tab">技术进展</span>
                <span class="filter-tab">行业动态</span>
            </div>

            <div class="news-search">
                <input type="text" placeholder="搜索资讯..." class="news-search-input">
                <button class="news-search-btn">🔍</button>
            </div>
        </div>
    </div>
</section>

<!-- 新闻列表 -->
<section class="news-list-section">
    <div class="section-container">
        <div class="news-list">
            {{#each newsItems}}
            <article class="news-card">
                {{#if image}}
                <div class="news-image">
                    <img src="{{image}}" alt="{{title}}" class="news-img">
                </div>
                {{/if}}
                <div class="news-content">
                    <div class="news-meta">
                        <span class="news-category">{{category}}</span>
                        <time class="news-date">{{date}}</time>
                    </div>
                    <h2 class="news-title">{{title}}</h2>
                    <p class="news-excerpt">这是新闻摘要内容，展示AI技术的最新发展和应用情况。</p>
                    <div class="news-actions">
                        <button class="news-read-btn">阅读全文</button>
                        <div class="news-stats">
                            <span class="news-views">👁 1.2K</span>
                            <span class="news-likes">❤️ 56</span>
                        </div>
                    </div>
                </div>
            </article>
            {{/each}}
        </div>

        <!-- 分页 -->
        <div class="pagination">
            <button class="pagination-btn" disabled>上一页</button>
            <div class="pagination-numbers">
                <span class="pagination-number active">1</span>
                <span class="pagination-number">2</span>
                <span class="pagination-number">3</span>
                <span class="pagination-dots">...</span>
                <span class="pagination-number">10</span>
            </div>
            <button class="pagination-btn">下一页</button>
        </div>
    </div>
</section>

<!-- 侧边栏推荐 -->
<aside class="news-sidebar">
    <div class="sidebar-section">
        <h3 class="sidebar-title">热门话题</h3>
        <div class="topic-tags">
            <span class="topic-tag">DeepSeek</span>
            <span class="topic-tag">GPT-4</span>
            <span class="topic-tag">AI视频生成</span>
            <span class="topic-tag">机器学习</span>
            <span class="topic-tag">自动驾驶</span>
            <span class="topic-tag">计算机视觉</span>
        </div>
    </div>

    <div class="sidebar-section">
        <h3 class="sidebar-title">推荐工具</h3>
        <div class="recommended-tools">
            <div class="recommended-tool">
                <img src="https://ext.same-assets.com/155488376/946268843.jpeg" alt="ChatGPT" class="tool-icon-small">
                <div class="tool-info-small">
                    <h4>ChatGPT</h4>
                    <p>智能对话助手</p>
                </div>
            </div>
            <div class="recommended-tool">
                <img src="https://ext.same-assets.com/155488376/614836080.jpeg" alt="Claude" class="tool-icon-small">
                <div class="tool-info-small">
                    <h4>Claude 4</h4>
                    <p>高级AI助手</p>
                </div>
            </div>
        </div>
    </div>
</aside>

<style>
.page-header {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    padding: 60px 0 40px 0;
    margin-bottom: 40px;
}

.page-title {
    font-size: 36px;
    font-weight: 700;
    color: #151719;
    margin-bottom: 8px;
    text-align: center;
}

.page-subtitle {
    color: #666;
    font-size: 18px;
    text-align: center;
    margin-bottom: 40px;
}

.news-filters {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
}

.filter-tabs {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
}

.filter-tab {
    padding: 8px 20px;
    border-radius: 20px;
    background: white;
    border: 1px solid #e1e5e9;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 14px;
}

.filter-tab.active {
    background: #56b3ce;
    color: white;
    border-color: #56b3ce;
}

.news-search {
    display: flex;
    align-items: center;
    background: white;
    border-radius: 24px;
    padding: 8px 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.news-search-input {
    border: none;
    outline: none;
    padding: 8px;
    font-size: 14px;
    width: 200px;
}

.news-search-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    opacity: 0.6;
}

.news-list-section {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

.news-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.news-card {
    background: white;
    border-radius: 12px;
    border: 1px solid #e1e5e9;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    gap: 20px;
}

.news-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
}

.news-image {
    flex: 0 0 200px;
}

.news-img {
    width: 100%;
    height: 150px;
    object-fit: cover;
}

.news-content {
    flex: 1;
    padding: 20px;
    display: flex;
    flex-direction: column;
}

.news-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
}

.news-category {
    background: #f0f9ff;
    color: #0369a1;
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
}

.news-date {
    color: #666;
    font-size: 12px;
}

.news-title {
    font-size: 18px;
    font-weight: 600;
    color: #151719;
    line-height: 1.4;
    margin-bottom: 12px;
}

.news-excerpt {
    color: #666;
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
}

.news-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.news-read-btn {
    background: #56b3ce;
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    border: none;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.2s;
}

.news-read-btn:hover {
    background: #4a9bb8;
}

.news-stats {
    display: flex;
    gap: 16px;
    font-size: 12px;
    color: #666;
}

.pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 40px;
    padding: 20px 0;
}

.pagination-btn {
    padding: 8px 16px;
    border: 1px solid #e1e5e9;
    background: white;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
}

.pagination-btn:hover:not(:disabled) {
    background: #f8f9fa;
}

.pagination-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.pagination-numbers {
    display: flex;
    gap: 4px;
}

.pagination-number {
    padding: 8px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
}

.pagination-number.active {
    background: #56b3ce;
    color: white;
}

.pagination-dots {
    padding: 8px 4px;
    color: #666;
}

.news-sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
}

.sidebar-section {
    background: white;
    border-radius: 12px;
    border: 1px solid #e1e5e9;
    padding: 24px;
    margin-bottom: 24px;
}

.sidebar-title {
    font-size: 18px;
    font-weight: 600;
    color: #151719;
    margin-bottom: 16px;
}

.topic-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.topic-tag {
    background: #f8f9fa;
    color: #495057;
    padding: 6px 12px;
    border-radius: 16px;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
}

.topic-tag:hover {
    background: #56b3ce;
    color: white;
}

.recommended-tools {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.recommended-tool {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 8px;
    transition: background 0.2s;
    cursor: pointer;
}

.recommended-tool:hover {
    background: #f8f9fa;
}

.tool-icon-small {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    object-fit: cover;
}

.tool-info-small h4 {
    font-size: 14px;
    font-weight: 500;
    color: #151719;
    margin-bottom: 2px;
}

.tool-info-small p {
    font-size: 12px;
    color: #666;
    margin: 0;
}

@media (max-width: 768px) {
    .news-list-section {
        grid-template-columns: 1fr;
    }

    .news-card {
        flex-direction: column;
    }

    .news-image {
        flex: none;
    }

    .news-img {
        height: 200px;
    }

    .news-filters {
        flex-direction: column;
        align-items: stretch;
    }

    .filter-tabs {
        justify-content: center;
    }
}
</style>

<div class="mcp-service-card">
    <a href="{{this.externalServiceUrl}}" target="_blank" class="mcp-service-card-link">
        <div class="mcp-service-card-image-container">
            {{#if this.imageUrl}}
                <img src="{{this.imageUrl}}" alt="{{this.name}} logo" class="mcp-service-card-image">
            {{else}}
                <img src="/images/placeholder-mcp.png" alt="{{this.name}} placeholder" class="mcp-service-card-image"> {{!-- Default placeholder --}}
            {{/if}}
        </div>
        <div class="mcp-service-card-content">
            <h3 class="mcp-service-card-title">
                {{this.name}}
                {{#if this.isVerified}}
                    <span class="mcp-verified-badge">已认证</span>
                {{/if}}
            </h3>
            <p class="mcp-service-card-description">{{this.description}}</p>
            <div class="mcp-service-card-footer">
                <span class="mcp-service-card-tech">{{this.languageOrTech}}</span>
                <div class="mcp-service-card-stats">
                    {{#if this.userCountOrStars}}
                    <span class="mcp-service-card-users">
                        <i class="fas fa-users"></i> {{#formatNumber this.userCountOrStars}}{{/formatNumber}} {{!-- Assuming a formatNumber helper --}}
                    </span>
                    {{/if}}
                    {{#if this.rating}}
                    <span class="mcp-service-card-rating">
                        <i class="fas fa-star"></i> {{this.rating}}分
                    </span>
                    {{/if}}
                </div>
            </div>
        </div>
    </a>
</div>

# Git
.git
.gitignore

# Node modules (installed within Docker)
node_modules

# Build output (generated within Docker builder stage)
dist

# Docker files
Dockerfile
.dockerignore
docker-compose.yml

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (should be passed at runtime, not built into image)
.env
.env.*
!/.env.example # Allow .env.example if it exists and is meant to be included

# OS generated files
.DS_Store
Thumbs.db

# Editor directories and files
.idea
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test files (if not needed in production image)
test/
coverage/
jest.config.js
jest-e2e.json

# Other temporary or local files
.tmp/
temp/
local/
# Add any other project-specific files/folders to ignore

# Markdown files (unless specifically needed in the image)
*.md
# If you have specific .md files needed, like for documentation display,
# you can negate them:
# !public/docs/IMPORTANT.md

# Cursor IDE specific
.cursor/

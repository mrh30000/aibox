<section class="mcp-hero-section">
    <div class="mcp-hero-content">
        <h1>{{heroData.title}}</h1>
        <p class="mcp-hero-subtitle">{{#if heroData.subtitle}}{{heroData.subtitle}}{{else}}Discover and integrate MCP services easily.{{/if}}</p>
        <form action="/mcp/search" method="GET" class="mcp-search-bar-container">
            <input type="text" name="q" placeholder="搜索MCP服务..." class="mcp-search-input" value="{{searchTerm}}">
            <button type="submit" class="mcp-search-button">搜索</button>
        </form>
    </div>
</section>
